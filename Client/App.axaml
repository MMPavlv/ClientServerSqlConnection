<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Client.App"
             xmlns:local="using:Client"
             RequestedThemeVariant="Light">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#F6F8FB" />
            <GradientStop Offset="0.6" Color="#F1F4F8" />
            <GradientStop Offset="1" Color="#E9EEF5" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#2D5F99" />
            <GradientStop Offset="1" Color="#244D7C" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FBFCFE" />
        <SolidColorBrush x:Key="SurfaceStrongBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F3F6FA" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D6DEE8" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#9EB1C7" />
        <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#1D2A3A" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#5A6B7F" />
        <SolidColorBrush x:Key="LogTextBrush" Color="#31465D" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FAEFF1" />
        <SolidColorBrush x:Key="DangerBorderBrush" Color="#DFC1C7" />
        <SolidColorBrush x:Key="DangerTextBrush" Color="#8C3B48" />
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window.main-window">
            <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
            <Setter Property="FontFamily" Value="avares://Avalonia.Fonts.Inter/Assets#Inter" />
        </Style>

        <Style Selector="Grid.root-layout">
            <Setter Property="Margin" Value="24" />
            <Setter Property="RowSpacing" Value="16" />
        </Style>

        <Style Selector="Grid.toolbar-layout">
            <Setter Property="ColumnSpacing" Value="10" />
        </Style>

        <Style Selector="TextBox.server-input">
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource SurfaceStrongBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="CaretBrush" Value="#365F94" />
        </Style>

        <Style Selector="TextBox.server-input:focus">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
        </Style>

        <Style Selector="Button.action-button">
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Button.primary-action">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
            <Setter Property="BorderBrush" Value="#2C578B" />
        </Style>

        <Style Selector="Button.primary-action:pointerover">
            <Setter Property="Background" Value="#2A5589" />
            <Setter Property="BorderBrush" Value="#234A77" />
        </Style>

        <Style Selector="Button.secondary-action">
            <Setter Property="Background" Value="{StaticResource SurfaceStrongBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>

        <Style Selector="Button.secondary-action:pointerover">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
        </Style>

        <Style Selector="Button.danger-action">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
        </Style>

        <Style Selector="Button.danger-action:pointerover">
            <Setter Property="Background" Value="#F6E4E7" />
            <Setter Property="BorderBrush" Value="#D1AAB3" />
        </Style>

        <Style Selector="Button.action-button:disabled">
            <Setter Property="Opacity" Value="0.5" />
        </Style>

        <Style Selector="TextBlock.version-card">
            <Setter Property="MinHeight" Value="144" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="{StaticResource SurfaceStrongBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="28" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="ScrollViewer.log-panel">
            <Setter Property="Background" Value="{StaticResource SurfaceStrongBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style Selector="ScrollViewer.log-panel:pointerover">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
        </Style>

        <Style Selector="SelectableTextBlock.log-output">
            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="LineHeight" Value="19" />
        </Style>

        <Style Selector="ItemsControl.notifications-host">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="20" />
            <Setter Property="MaxWidth" Value="340" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style Selector="Border.notification-card">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BoxShadow" Value="0 8 24 0 #12091B2B" />
        </Style>

        <Style Selector="StackPanel.notification-stack">
            <Setter Property="Spacing" Value="4" />
        </Style>

        <Style Selector="TextBlock.notification-title">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="TextBlock.notification-message">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="0.88" />
        </Style>
    </Application.Styles>
</Application>
